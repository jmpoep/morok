# Pinned upstream LLVM trunk commit that Morok builds against.
#
# Morok targets the New-PM plugin API exposed at <llvm/Plugins/PassPlugin.h>
# with LLVM_PLUGIN_API_VERSION 2. That header/version was introduced UPSTREAM by
#   https://github.com/llvm/llvm-project/pull/173279
#   (commit f54df0d09e19ec6b205cb0af45c7ecea2fd8aeff, 2025-12-22,
#    "[LLVM][NFC] Move PassPlugin from Passes to separate library")
# so any llvm/llvm-project trunk commit at or after that point is usable. There
# is no fork: this is plain upstream trunk.
#
# Pinning a specific trunk commit keeps the (expensive) LLVM build caches warm
# across normal pushes; .github/workflows/llvm-bump.yml advances this pin on a
# schedule so we keep tracking trunk. Bump it by editing LLVM_REF below.
LLVM_REF=05c8f9b1ead844024f414f45ab9ba11757bef2ea
