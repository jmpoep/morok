# Pinned upstream LLVM trunk commit that Morok is built against.
#
# Morok targets the New-PM plugin API at <llvm/Plugins/PassPlugin.h> with
# LLVM_PLUGIN_API_VERSION 2 (introduced upstream by llvm/llvm-project#173279,
# commit f54df0d09e19, 2025-12-22). Any trunk commit at or after that works; this
# is plain upstream trunk, not a fork.
#
# We build LLVM from source (the LLVM.org prebuilt release toolchains cannot be
# linked against on macOS — their libc++ has diverged from Apple's — and Morok
# also uses trunk-only LLVM APIs). The build is expensive once per pinned commit
# and then cached by SHA, so day-to-day runs are minutes.
#
# Bumped by .github/workflows/llvm-bump.yml as trunk advances.
LLVM_REF=56385af687c3a7a1f67716fb3f819336789a8cab
